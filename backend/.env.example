# Deploy AI
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret
ORG_ID=your-org-id
AUTH_URL=https://api-auth.dev.deploy.ai/oauth2/token
API_URL=https://core-api.dev.deploy.ai

# LLM Provider
# Choose: "openai" or "anthropic". In demo mode, real LLM keys are optional.
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: override per-agent models.
# MODEL_NAVIGATOR=gpt-4o-mini
# MODEL_SENTINEL=gpt-4o
# MODEL_HERALD=gpt-4o-mini

# App Config
JWT_SECRET=change-me-local-dev-secret
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=admin123
DEMO_MODE=true
PORT=3001
WORKERS=1
LOG_LEVEL=info

# Database
# Root docker-compose sets this automatically for the backend container.
# For local runs, point this at a running PostgreSQL database.
DATABASE_URL=postgresql://releaseops:releaseops_secret@localhost:5432/releaseops

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@yourdomain.com
