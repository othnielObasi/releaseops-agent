# ── Deploy AI ──────────────────────────────────
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret
ORG_ID=your-org-id
AUTH_URL=https://api-auth.dev.deploy.ai/oauth2/token
API_URL=https://core-api.dev.deploy.ai

# ── LLM Provider ──────────────────────────────
# Choose: "openai" or "anthropic" (admin can also change at runtime via API)
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override per-agent models (defaults are auto-selected per provider)
# MODEL_NAVIGATOR=gpt-4o-mini
# MODEL_SENTINEL=gpt-4o
# MODEL_HERALD=gpt-4o-mini

# ── App Config ───────────JWT_SECRET=              # REQUIRED — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=          # REQUIRED — strong password for the bootstrap admin account
DEMO_MODE=false
PORT=3001
WORKERS=1
LOG_LEVEL=info

# ── Email (optional) ───────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
FROM_EMAIL=noreply@yourdomain.com
